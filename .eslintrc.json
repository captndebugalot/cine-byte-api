{
  "env": {
    "node": true,
    "es2024": true
  },
  "extends": ["eslint:recommended", "prettier"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "overrides": [
    {
      "files": ["**/*.test.js"],
      "env": {
        "jest": true
      }
    }
  ],
  "ignorePatterns": [".github/**", "testUtils.js", "jest.config.js"]
}
